[Unit]
Description=URLShelf
After=network-online.target
Wants=network-online.target

[Container]
Image=ghcr.io/shirayu/urlshelf:latest
AutoUpdate=registry
ContainerName=urlshelf
HostName=urlshelf
PublishPort=9432:9432
Volume=/opt/data/urlshelf:/data:Z
Environment=URLSHELF_DB_PATH=/data/db.sqlite3
UserNS=keep-id

[Service]
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target default.target
